# ═══════════════════════════════════════════════════════════
# StoreWise — Supabase + Vercel Configuration
# ═══════════════════════════════════════════════════════════

# Supabase (get from supabase.com > Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Email (for weekly reports — Gmail SMTP is free)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=StoreWise <reports@yourdomain.com>

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
DEFAULT_TAX_RATE=0.0825

# NRS POS Integration
NRS_USER_TOKEN=your_nrs_token_here
NRS_API_BASE=https://pos-papi.nrsplus.com

# Cron Jobs
CRON_SECRET=generate-a-random-string-here

# Optional: Resend.com email alerts (for NRS sync failure notifications)
RESEND_API_KEY=
